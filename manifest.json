{
  "manifest_version": 3,
  "name": "AI Chrome Extension",
  "version": "1.0",
  "description": "AI text autocomplete extension for text fields on websites.",
  "permissions": [],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}